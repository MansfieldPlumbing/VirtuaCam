```gitignore
# PowerShell modules and packages
Modules/
*.psd1
*.psm1

# Dependencies
node_modules/
vendor/

# Logs and temporary files
*.log
*.tmp
*.temp

# Environment variables
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/
target/
bin/
obj/

# OS generated files
.DS_Store
Thumbs.db

# Python related (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage
htmlcov/
.coverage.*
.pytest_cache/
.mypy_cache/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```